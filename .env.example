# ──────────────────────────────────────────────
# Copia este archivo como .env y completa los valores
# cp .env.example .env
# ──────────────────────────────────────────────

# Base de datos MySQL
MYSQL_ROOT_PASSWORD=cambia-esta-password-root
MYSQL_DATABASE=peluqueria
MYSQL_USER=stratus
MYSQL_PASSWORD=cambia-esta-password-stratus

# Backend
# Clave secreta para el endpoint /auth/superadmin/setup (úsala una sola vez)
SUPERADMIN_SETUP_SECRET=clave-secreta-larga-y-aleatoria

# Dominio de producción (sin https://, sin www)
# Permite CORS para tudominio.com y *.tudominio.com
PRODUCTION_DOMAIN=tudominio.com

# URL pública de la API — se usa en el BUILD de los tres frontends
# Debe ser la URL con la que el navegador del cliente llega al backend
VITE_API_URL=https://api.tudominio.com
